<?xml version="1.0" encoding="utf-8"?>
<style xmlns="http://purl.org/net/xbiblio/csl" class="in-text" version="1.0" demote-non-dropping-particle="never" default-locale="en-GB">
  <info>
    <title>IASPM Journal (International Association for the Study of Popular Music)</title>
    <title-short>IASPM Journal</title-short>
    <id>http://www.zotero.org/styles/iaspm-journal</id>
    <link href="http://www.zotero.org/styles/iaspm-journal" rel="self"/>
    <link href="http://www.zotero.org/styles/elsevier-harvard" rel="template"/>
    <link href="https://iaspmjournal.net/index.php/IASPM_Journal/article/view/583/dotx" rel="documentation"/>
    <author>
      <name>Steven Gamble</name>
    </author>
    <category citation-format="author-date"/>
    <category field="humanities"/>
    <summary>IASPM Journal Harvard style</summary>
    <updated>2026-07-09T12:36:08+00:00</updated>
    <rights license="http://creativecommons.org/licenses/by-sa/3.0/">This work is licensed under a Creative Commons Attribution-ShareAlike 3.0 License</rights>
  </info>
  <locale xml:lang="en">
    <terms>
      <term name="interview">interview by</term>
      <term name="director" form="short">Dir.</term>
      <term name="editor" form="short">Ed.</term>
      <term name="online">online</term>
    </terms>
  </locale>
  <macro name="author">
    <names variable="author">
      <name name-as-sort-order="all" sort-separator=", " initialize-with=". " delimiter=", " and="text" delimiter-precedes-last="always"/>
      <label form="short" prefix=", " suffix="."/>
      <substitute>
        <names variable="editor"/>
        <names variable="director"/>
        <text variable="title" text-case="title"/>
      </substitute>
    </names>
  </macro>
  <macro name="author-short">
    <names variable="author">
      <name form="short" and="text" delimiter=", " initialize-with=". "/>
      <substitute>
        <names variable="editor"/>
        <names variable="director"/>
        <text variable="title" form="short" text-case="title"/>
      </substitute>
    </names>
  </macro>
  <macro name="issued-year">
    <choose>
      <if variable="issued">
        <date variable="issued">
          <date-part name="year"/>
        </date>
      </if>
      <else>
        <text term="no date" form="short"/>
      </else>
    </choose>
  </macro>
  <citation et-al-min="3" et-al-use-first="1" disambiguate-add-year-suffix="true" collapse="year">
    <sort>
      <key macro="author-short"/>
      <key macro="issued-year"/>
    </sort>
    <layout prefix="(" suffix=")" delimiter="; ">
      <group delimiter=": ">
        <group delimiter=" ">
          <text macro="author-short"/>
          <text macro="issued-year"/>
        </group>
        <text variable="locator"/>
      </group>
    </layout>
  </citation>
  <bibliography hanging-indent="true" entry-spacing="1" line-spacing="2" et-al-min="3" et-al-use-first="1">
    <sort>
      <key macro="author"/>
      <key macro="issued-year"/>
      <key variable="title"/>
    </sort>
    <layout suffix=".">
      <choose>
        <if type="motion_picture" match="any">
          <choose>
            <if variable="URL">
              <text macro="author"/>
              <text macro="issued-year" prefix=" (" suffix=")"/>
              <text variable="title" text-case="title" prefix=" " suffix=" [Online video]."/>
              <text variable="URL" prefix=" Available from: " suffix="."/>
              <date variable="accessed" prefix=" Accessed " form="text"/>
            </if>
            <else>
              <text variable="title" font-style="italic" text-case="title" suffix="."/>
              <text macro="issued-year" prefix=" " suffix="."/>
              <names variable="director" prefix=" " suffix=",">
                <label form="short" suffix=" " text-case="capitalize-first"/>
                <name initialize-with=". " and="text" delimiter=", "/>
              </names>
              <text variable="publisher" prefix=" "/>
            </else>
          </choose>
        </if>
        <else-if type="post-weblog" match="any">
          <text macro="author"/>
          <text macro="issued-year" prefix=" (" suffix=")"/>
          <text variable="title" prefix=" " suffix=" [Online video]."/>
          <text variable="URL" prefix=" Available from: " suffix="."/>
          <date variable="accessed" prefix=" Accessed " form="text"/>
        </else-if>
        <else-if type="broadcast" match="any"/>
        <else>
          <text macro="author" suffix="."/>
          <text macro="issued-year" prefix=" " suffix="."/>
          <choose>
            <if type="article-journal" match="any">
              <text variable="title" text-case="title" prefix=" " suffix="."/>
              <group prefix=" " suffix="." delimiter=" ">
                <text variable="container-title" font-style="italic" text-case="title"/>
                <text variable="volume"/>
                <text variable="issue" prefix="(" suffix="):"/>
                <text variable="page"/>
              </group>
              <choose>
                <if variable="DOI">
                  <text variable="DOI" prefix=" https://doi.org/"/>
                </if>
              </choose>
            </if>
            <else-if type="article-magazine article-newspaper" match="any">
              <text variable="title" text-case="title" prefix=" " suffix="."/>
              <group prefix=" " suffix="." delimiter=", ">
                <text variable="container-title" font-style="italic" text-case="title"/>
                <date variable="issued" delimiter=" ">
                  <date-part name="day"/>
                  <date-part name="month"/>
                </date>
              </group>
              <choose>
                <if variable="URL">
                  <text variable="URL" prefix=" " suffix="."/>
                  <date variable="accessed" prefix=" Accessed: " form="text"/>
                </if>
              </choose>
            </else-if>
            <else-if type="book thesis" match="any">
              <choose>
                <if type="thesis">
                  <text variable="title" font-style="italic" text-case="title" prefix=" " suffix="."/>
                  <group prefix=" " delimiter=". ">
                    <text variable="genre"/>
                    <text variable="publisher"/>
                    <text variable="publisher-place"/>
                  </group>
                  <choose>
                    <if variable="URL">
                      <group prefix=" " delimiter=" ">
                        <text variable="URL"/>
                        <date variable="accessed" prefix="Accessed: " form="text"/>
                      </group>
                    </if>
                  </choose>
                </if>
                <else>
                  <text variable="title" font-style="italic" text-case="title" prefix=" " suffix="."/>
                  <group prefix=" " delimiter=": ">
                    <text variable="publisher-place"/>
                    <text variable="publisher"/>
                  </group>
                </else>
              </choose>
            </else-if>
            <else-if type="chapter paper-conference" match="any">
              <text variable="title" text-case="title" prefix=" " suffix="."/>
              <group prefix=" " delimiter=" ">
                <text term="in" text-case="capitalize-first"/>
                <names variable="editor">
                  <name name-as-sort-order="all" sort-separator=", " initialize="false" delimiter=", " and="text"/>
                  <label form="short" prefix=" "/>
                </names>
                <text variable="container-title" font-style="italic" text-case="title" suffix="."/>
                <group delimiter=": ">
                  <text variable="publisher-place"/>
                  <text variable="publisher"/>
                </group>
              </group>
              <text variable="page" prefix=": "/>
            </else-if>
            <else-if type="webpage">
              <text variable="title" text-case="title" prefix=" " suffix="."/>
              <group prefix=" " delimiter=" ">
                <text variable="URL"/>
                <date variable="accessed" prefix="Accessed: " form="text"/>
              </group>
            </else-if>
            <else-if type="song" match="any">
              <text variable="title" prefix=" “" suffix="”," text-case="title"/>
              <group prefix=" " delimiter=", ">
                <text variable="collection-title" font-style="italic"/>
                <text variable="publisher"/>
                <date variable="issued" delimiter=" ">
                  <date-part name="day"/>
                  <date-part name="month"/>
                </date>
                <text variable="publisher-place"/>
              </group>
            </else-if>
            <else-if type="entry-encyclopedia" match="any">
              <text variable="title" text-case="title" prefix=" " suffix="."/>
              <group prefix=" " delimiter=" ">
                <text term="in" text-case="capitalize-first"/>
                <choose>
                  <if variable="volume collection-title" match="any">
                    <text variable="container-title" font-style="italic" text-case="title" suffix=","/>
                    <group delimiter=", ">
                      <group>
                        <text term="volume" form="short" text-case="capitalize-first" suffix=" "/>
                        <text variable="volume"/>
                      </group>
                      <text variable="collection-title"/>
                    </group>
                  </if>
                  <else>
                    <text variable="container-title" font-style="italic" text-case="title"/>
                  </else>
                </choose>
              </group>
              <text variable="page" prefix=": "/>
            </else-if>
            <else>
              <text variable="title" text-case="title" prefix=" " suffix="."/>
              <text variable="container-title" font-style="italic" prefix=" "/>
            </else>
          </choose>
        </else>
      </choose>
    </layout>
  </bibliography>
</style>
